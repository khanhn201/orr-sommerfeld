      include "experimental/lvlSet.f"
      include "experimental/lserrors.f"
c-----------------------------------------------------------------------
      subroutine uservp(ix,iy,iz,eg) ! set variable properties
      implicit none
      integer ix,iy,iz,eg,e
     
      include 'SIZE'
      include 'TOTAL'
      include 'NEKUSE'

      common /ls_usr/ ifld_cls,ifld_clsr,
     $                ifld_tls,ifld_tlsr 
      integer ifld_cls,ifld_clsr
      integer ifld_tls,ifld_tlsr

      common /fsos_usr/ rhol, rhog, mul, mug,
     $                  facc, gacc, sigma_sf
      real rhol, rhog, mul, mug, facc, gacc, sigma_sf

      real psi, evm_getvisc
      real Re

      integer icalld
      save icalld
      data icalld /0/

      e = gllel(eg)

!     These routine is not called by external solver
!     To Do: change the flow, so that this routine is called
!     similar to RANS. Will avoid confusion

      Re = rhol/mul

      if(ifield.eq.1)then
        psi = t(ix,iy,iz,e,ifld_cls-1)
        psi = max(0.0,psi)
        psi = min(1.0,psi)
        utrans = ((1.0-psi)*rhog + psi*rhol)/rhol
        udiff = ((1.0-psi)*mug + psi*mul)/mul/Re

        if(istep.le.2)then
          vtrans0(ix,iy,iz,e) = utrans
        else
          vtrans0(ix,iy,iz,e) = utrans
c         vtrans0(ix,iy,iz,e) = rhog/rhol
        endif
      else
        utrans = 1.0
        udiff = 1e-10
        if(ifavm(ifield-1))then
          udiff = 1e-10       !must be tiny for hyperbolic
        elseif(ifsvv(ifield-1))then
          udiff = 1e-10      !must be tiny for hyperbolic
        endif
      endif

      return
      end
c-----------------------------------------------------------------------
      subroutine userf(ix,iy,iz,eg) ! set acceleration term
      implicit none
      integer ix,iy,iz,eg,e

      include 'SIZE'
      include 'TOTAL'
      include 'NEKUSE'

      common /ls_usr/ ifld_cls,ifld_clsr,
     $                ifld_tls,ifld_tlsr 
      integer ifld_cls,ifld_clsr
      integer ifld_tls,ifld_tlsr

      common /fsos_usr/ rhol, rhog, mul, mug,
     $                  facc, gacc, sigma_sf
      real rhol, rhog, mul, mug, facc, gacc, sigma_sf

      integer lxyz
      parameter (lxyz=lx1*ly1*lz1)
      common /indct/ phi(lxyz,lelt)
     $ ,fx(lx1,ly1,lz1,lelt),fy(lx1,ly1,lz1,lelt),fz(lx1,ly1,lz1,lelt)
      real phi, fx, fy, fz

      real sfx,sfy,sfz
      real fbx,fby,fbz
      real svvx,svvy,svvz
      real psi, fgrav, fflow


      e = gllel(eg)

      sfx = 0.0
      sfy = 0.0
      sfz = 0.0
      svvx = 0.0
      svvy = 0.0
      svvz = 0.0

      call surfacetension(ix,iy,iz,e,sigma_sf,sfx,sfy,sfz)
      call svv_fluid(ix,iy,iz,e,svvx,svvy,svvz)

      psi = t(ix,iy,iz,e,ifld_cls-1)

      fgrav = vtrans(ix,iy,iz,e,1)*gacc
      fflow = vtrans(ix,iy,iz,e,1)*facc

      fbx = fx(ix,iy,iz,e)/vtrans(ix,iy,iz,e,1)
      fby = fy(ix,iy,iz,e)/vtrans(ix,iy,iz,e,1)
      fbz = fz(ix,iy,iz,e)/vtrans(ix,iy,iz,e,1)

      ! explicit
      sfx = sfx/vtrans(ix,iy,iz,e,1)
      sfy = sfy/vtrans(ix,iy,iz,e,1)
      sfz = sfz/vtrans(ix,iy,iz,e,1)
      ffx = sfx + svvx + fflow/vtrans(ix,iy,iz,e,1) + fbx
      ffy = sfy + svvy - fgrav/vtrans(ix,iy,iz,e,1) + fby
      ffz = sfz + svvz + fbz
      abfx(ix,iy,iz,e) = 0.0
      abfy(ix,iy,iz,e) = 0.0
      abfz(ix,iy,iz,e) = 0.0

      return
      end
c-----------------------------------------------------------------------
      subroutine userq(ix,iy,iz,eg) ! set source term
      implicit none
      integer ix,iy,iz,eg,e

      include 'SIZE'
      include 'TOTAL'
      include 'NEKUSE'
      real signls

      e = gllel(eg)
      
      qvol = 0.0
      avol = 0.0

      call limit_cls(ix,iy,iz,e)

      return
      end
c-----------------------------------------------------------------------
      subroutine userbc(ix,iy,iz,iside,eg) ! set up boundary conditions
      implicit none
      integer ix,iy,iz,iside,eg

      include 'SIZE'
      include 'TOTAL'
      include 'NEKUSE'

      integer e
      real xx,yy

      e = gllel(eg)

      xx = xm1(ix,iy,iz,e)
      yy = ym1(ix,iy,iz,e)

      ux   = 0.0
      uy   = 0.0
      uz   = 0.0

      return
      end
c-----------------------------------------------------------------------
      subroutine useric(ix,iy,iz,eg) ! set up initial conditions
      implicit none
      integer ix,iy,iz,eg,e

      include 'SIZE'
      include 'TOTAL'
      include 'NEKUSE'

      common /ls_usr/ ifld_cls,ifld_clsr,
     $                ifld_tls,ifld_tlsr 
      integer ifld_cls,ifld_clsr
      integer ifld_tls,ifld_tlsr
      real xx,yy, x_max

      common /fsarray/ ub(lx1,ly1,lz1,lelt),vb(lx1,ly1,lz1,lelt)
      real ub, vb
      common /fstemp/ temp_ic(lx1,ly1,lz1,lelv,2)
      real temp_ic
      real fsr, fsi, ax, disp, heaviside, h_local

      e = gllel(eg)

      xx = xm1(ix,iy,iz,e)
      yy = ym1(ix,iy,iz,e)

      ux = ub(ix,iy,iz,e)
      uy = vb(ix,iy,iz,e)
      uz = 0.0

      if(ifield.eq.2)then
        temp = temp_ic(ix, iy, iz, e, 1)
      endif
      if(ifield.eq.3)then
        temp = temp_ic(ix, iy, iz, e, 2)
      endif
      if(ifield.eq.4)then
        temp = temp_ic(ix, iy, iz, e, 1)
      endif
      if(ifield.eq.5)then
        temp = temp_ic(ix, iy, iz, e, 2)
      endif

      return
      end
c-----------------------------------------------------------------------
      subroutine userchk()
      implicit none
      include 'SIZE'
      include 'TOTAL'

      real ntlsr, nclsr

      integer ntot,i

      real glsum, glsc3, glsc2
      integer pord
      integer ncut

      integer nface, f, e
      real bfluid(lx1*ly1*lz1*lelt)
      real psifluid(lx1,ly1,lz1,lelv)
      real pr_avg

      real vol, vy2, vy20, gr, gl, ge, vy2r, vy2l,timestart
      real gle
      real vf20, vf2l, vg20, vg2l, vf2, vg2
      real gfr, gfl, gfe, gfle
      real ggr, ggl, gge, ggle
      real vf2r, vg2r

      save vy20, vy2l, timestart
      save vf20, vf2l, vg20, vg2l

      common /fsarray/ ub(lx1,ly1,lz1,lelt),vb(lx1,ly1,lz1,lelt)
      common /fstemp/ temp_ic(lx1,ly1,lz1,lelv,2)
      common /fsparam/ eps,alpha,gamma_r,gamma_i
      real ub, vb
      real temp_ic, eps, alpha, gamma_r, gamma_i

      integer lxyz, lt
      parameter (lxyz=lx1*ly1*lz1,lt=lxyz*lelt)
      common /indct/ phi(lxyz,lelt),fx(lt),fy(lt),fz(lt)
      real phi, fx, fy, fz

      ntot = lx1*ly1*lz1*nelv

      ! Initialize the first 5 steps with the same IC
      if (istep.lt.5) then
        call gen_pert_ic
        call copy(t(1,1,1,1,1),temp_ic(1,1,1,1,1),ntot)
        call copy(t(1,1,1,1,3),temp_ic(1,1,1,1,1),ntot)
        do i=1,ntot
          vx(i,1,1,1) = ub(i,1,1,1)
          vy(i,1,1,1) = vb(i,1,1,1)
        enddo
      endif

      ! Calculate growth rate
      vol = glsum(bm1,ntot)
      vy2 = glsc3(vy,bm1,vy,ntot)/vol

      call copy(psifluid,t,ntot)
      call col3(bfluid, bm1, psifluid, ntot)
      vol = glsum(bfluid,ntot)
      vf2 = glsc3(vy,bfluid,vy,ntot)/vol
      
      do i=1,ntot
        psifluid(i,1,1,1) = 1.0-psifluid(i,1,1,1)
      enddo
      call col3(bfluid, bm1, psifluid, ntot)
      vol = glsum(bfluid,ntot)
      vg2 = glsc3(vy,bfluid,vy,ntot)/vol

      if (vy2.gt.0.0) vy2 = sqrt(vy2)
      if (vg2.gt.0.0) vg2 = sqrt(vg2)
      if (vf2.gt.0.0) vf2 = sqrt(vf2)

      vy2r = vy2/vy20
      vy2l = vy2/vy2l
      gr = log(vy2r)/(time-timestart)
      gl = log(vy2l)/dt
      ge = abs(gr - gamma_r)/gamma_r
      gle = abs(gl - gamma_r)/gamma_r

      vf2r = vf2/vf20
      vf2l = vf2/vf2l
      gfr = log(vf2r)/(time-timestart)
      gfl = log(vf2l)/dt
      gfe = abs(gfr - gamma_r)/gamma_r
      gfle = abs(gfl - gamma_r)/gamma_r

      vg2r = vg2/vg20
      vg2l = vg2/vg2l
      ggr = log(vg2r)/(time-timestart)
      ggl = log(vg2l)/dt
      gge = abs(ggr - gamma_r)/gamma_r
      ggle = abs(ggl - gamma_r)/gamma_r

      if (istep.le.50) then
         vy20 = vy2
         vg20 = vg2
         vf20 = vf2
         timestart=time
      endif
      if (istep.ge.2) then
         if (nid.eq.0) write(6,1) istep,time,gl,gr,gle,ge
    1    format(i8,1p5e15.7,' AMPall')
         if (nid.eq.0) write(6,2) istep,time,gfl,gfr,gfle,gfe
    2    format(i8,1p5e15.7,' AMPfluid')
         if (nid.eq.0) write(6,3) istep,time,ggl,ggr,ggle,gge
    3    format(i8,1p5e15.7,' AMPgas')
      endif
      vy2l = vy2
      vf2l = vf2
      vg2l = vg2

      ifield = 6
      call set_inductionless_forcing
      ifield = 1
      call copy(t(1,1,1,1,5),phi,ntot)



      pord = uparam(3)
      call extrappr(prext,pr,prlag(1,1,1,1,1),prlag(1,1,1,1,2),pord)

      ntlsr = uparam(1) !freq of TLS re-distancing
      nclsr = uparam(2) !freq of CLS re-distancing

      call LS_default_driver(ntlsr,nclsr)

      return
      end
