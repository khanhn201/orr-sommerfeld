c-----------------------------------------------------------------------
      subroutine usrdat2()  ! This routine to modify mesh coordinates
      implicit none

      include 'SIZE'
      include 'TOTAL'

      common /ls_usr/ ifld_cls,ifld_clsr,
     $                ifld_tls,ifld_tlsr 
      integer ifld_cls,ifld_clsr
      integer ifld_tls,ifld_tlsr

      integer ntot,i, iface, iel
      real xx, yy
      real xlength

      common /scruz/ wk(ly1,1000)
      real wk
      real alpha

      ifld_cls = 2
      ifld_tls = 3
      ifld_clsr = 4
      ifld_tlsr = 5
      
      ntot = lx1*ly1*lz1*nelt
      if (nid.eq.0) then
         open(unit=98,file='u2.txt')
         read(98,*)      ! skip
         read(98,*)      ! skip
         read(98,*)      ! skip
         read(98,*)      ! skip
         read(98,*) alpha
         close(98)
      else
         alpha = 0.0
      endif
      call gop ( alpha , wk , '+  ', 1 )

      xlength = 2*pi/alpha
      call rescale_x (xm1,0.0,xlength)

      do iel=1,nelt
         do iface = 1, 2*ldim
            if (cbc(iface,iel,1) .eq. 'SYM') then
               cbc(iface,iel,1) = 'W  '
c              cbc(iface,iel,1) = 'v  '
            endif
         enddo
      enddo

      call gen_pert_ic ! perturbation i.c.s

      return
      end
c-----------------------------------------------------------------------
      subroutine usrdat3()
      implicit none

      include 'SIZE'
      include 'TOTAL'
      include 'SVV'
      include 'AVM'

      real eps,dt_cls_in,dt_tls_in
      integer nsteps_cls, nsteps_tls

      common /ls_usr/ ifld_cls,ifld_clsr,
     $                ifld_tls,ifld_tlsr 
